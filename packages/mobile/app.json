{
  "expo": {
    "name": "CommonGround",
    "slug": "commonground",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#080808"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.axm.commonground",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080808"
      },
      "package": "com.axm.commonground",
      "versionCode": 1
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "scheme": "commonground",
    "extra": {
      "eas": {
        "projectId": "axm-commonground"
      }
    }
  }
}
