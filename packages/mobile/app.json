{
  "expo": {
    "name": "CommonGround",
    "slug": "commonground",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#080808"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.axm.commonground",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080808"
      },
      "package": "com.axm.commonground",
      "versionCode": 1,
      "buildAttributes": {
        "minSdkVersion": 24,
        "targetSdkVersion": 34,
        "compileSdkVersion": 34
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "scheme": "commonground",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "21c7aff0-6263-47b8-8f17-6ccabab6f504"
      }
    }
  }
}
