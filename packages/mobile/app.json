{
  "expo": {
    "name": "CommonGround",
    "slug": "commonground",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#080808"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.axm.commonground",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "CommonGround needs access to your camera for secure identity verification.",
        "NSMicrophoneUsageDescription": "CommonGround needs access to your microphone for voice features.",
        "NSPhotoLibraryUsageDescription": "CommonGround needs access to your photos to share moments."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080808"
      },
      "package": "com.axm.commonground",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          },
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 34,
            "targetSdkVersion": 34
          }
        }
      ]
    ],
    "scheme": "commonground",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "1cd26756-b17d-405d-a25b-5827d0ecca62"
      }
    },
    "owner": "cursedanomaly"
  }
}
