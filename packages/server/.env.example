# CommonGround server runtime
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173

# PostgreSQL connection used by Drizzle and pg
DATABASE_URL=postgres://postgres:postgres@localhost:5432/axm_commonground

# Groq API key for free inference (llama-3.3-70b-versatile)
GROQ_API_KEY=

# JWT secret for token signing (generate with: openssl rand -base64 32)
JWT_SECRET=

# Optional AI provider credentials (fallback providers)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
VENICE_API_KEY=
VENICE_BASE_URL=https://api.venice.ai/api/v1
VENICE_MODEL=venice-uncensored

# Development authentication fallback
DEV_AUTH_TOKEN_PREFIX=dev-user-
