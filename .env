# CommonGround Environment Variables
# Free tier configuration - $0 cost

# Database (your existing Supabase)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_ID:YOUR_PASSWORD@YOUR_HOST.supabase.co:5432/postgres

# Server
JWT_SECRET=change-this-to-a-random-secret-in-production
NODE_ENV=production
PORT=3000

# Groq (FREE - fast inference)
GROQ_API_KEY=gsk_YOUR_GROQ_API_KEY_HERE

# Optional - leave empty if not using
ANTHROPIC_API_KEY=
VENICE_API_KEY=
