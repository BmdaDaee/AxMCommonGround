# ============================================================
# AxMCommonGround — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# --- Database ---
DATABASE_URL=mysql://user:password@host:3306/dbname

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- AI: Anthropic Claude (primary LLM) ---
CLAUDE_API_KEY=sk-ant-your-key

# --- AI: Venice AI (DeeplyUs unfiltered mode) ---
VENICE_API_KEY=your-venice-key

# --- AI: Forge API (image generation + Gemini completions) ---
FORGE_API_KEY=your-forge-key
FORGE_API_URL=https://forge.manus.im/v1

# --- AWS S3 (avatar + couple portrait storage) ---
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# --- OAuth ---
OAUTH_SERVER_URL=https://your-oauth-server.com

# --- Server ---
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
