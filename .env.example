# CommonGround Environment Variables
# Copy this to .env and fill in your actual values

# ============================================
# BACKEND & DATABASE (Server)
# ============================================

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres.PROJECT_ID:PASSWORD@PROJECT_ID.supabase.co:5432/postgres

# Server Configuration
JWT_SECRET=generate-a-random-secret-with-openssl-rand-hex-32
NODE_ENV=production
PORT=3000

# ============================================
# AI PROVIDERS
# ============================================

# Groq (FREE - fast inference)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Venice (Unfiltered alternative layer)
VENICE_API_KEY=your-venice-key-here

# ============================================
# MOBILE APP (Expo)
# ============================================

# CRITICAL: Set this before building mobile app
# This is where the Expo app will connect to for API calls
EXPO_PUBLIC_API_URL=https://cgo.anarchyxmayhem.com

# Environment for mobile (development, staging, production)
EXPO_PUBLIC_ENV=production
